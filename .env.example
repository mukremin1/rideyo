# Copy this file to .env and fill in your values.
#   Windows:  copy .env.example .env
#   macOS/Linux:  cp .env.example .env
#
# Supabase → Project Settings → API
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Public site URL for email confirmation links (required for mobile/APK sign-up).
VITE_SITE_URL=https://www.ride-yo.com

# Optional — local web + server dev only (npm run dev:full).
# Remove or comment out before mobile/APK builds (npm run mobile:sync).
# VITE_SERVER_API_URL=http://localhost:3001
# VITE_PAYMENT_API_URL=http://localhost:3001

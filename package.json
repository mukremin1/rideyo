  "scripts": {
    "predev": "node scripts/validate-env.mjs --mode=development",
    "dev": "vite",
    "build": "node scripts/validate-env.mjs && vite build && node scripts/copy-404.mjs && node scripts/verify-build.mjs",
    "build:mobile": "node scripts/validate-env.mjs && set CAPACITOR=true && vite build",
    "mobile:sync": "npm run build:mobile && npx cap sync android",
    "mobile:sync:ios": "npm run build:mobile && npx cap sync ios",
    "mobile:sync:all": "npm run build:mobile && npx cap sync",
    "ios:open": "npx cap open ios",
    "ios:prepare": "node scripts/prepare-ios.mjs",
    "assets:brand": "node scripts/generate-brand-assets.mjs",

# Supabase Edge Function secrets
# Set in Dashboard → Edge Functions → Secrets, or via CLI:
#   npx supabase secrets set --env-file supabase/secrets.env
#
# Do not commit a filled secrets.env file.

# --- Payment (iyzico sandbox) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_SANDBOX=true
IYZICO_CALLBACK_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/payment-callback

# App URL for payment redirects (web or deep link base)
APP_URL=https://your-app-url.com

# Platform fee (0.15 = 15%)
PLATFORM_COMMISSION_RATE=0.15

# true = demo payments without iyzico; false = require real iyzico keys
PAYMENT_DEMO_MODE=true

# --- Optional (AI chat / support) ---
LOVABLE_API_KEY=

# --- Verification email (edge function resend-verification) ---
# Get free key at https://resend.com — then:
#   npx supabase secrets set RESEND_API_KEY=re_xxx RESEND_FROM="RideYo <onboarding@resend.dev>" APP_URL=https://www.ride-yo.com
RESEND_API_KEY=
RESEND_FROM=RideYo <onboarding@resend.dev>

# --- Deploy CLI (local machine / CI, not edge secrets) ---
# SUPABASE_ACCESS_TOKEN=sbp_...
